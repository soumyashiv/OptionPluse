{
  "expo": {
    "name": "OptionPluse",
    "slug": "optionpluse",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/opplus-icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/opplus-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0D14"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.optionpluse.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/opplus-icon.png",
        "backgroundColor": "#0A0D14"
      },
      "package": "com.optionpluse.app",
      "versionCode": 1,
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "usesCleartextTraffic": true,
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE"
      ]
    },
    "web": {
      "favicon": "./assets/opplus-icon.png"
    },
    "extra": {
      "eas": {
        "projectId": "654b5826-adb5-488f-b01f-ecf68a9c28d0"
      }
    },
    "owner": "zeon-studios"
  }
}